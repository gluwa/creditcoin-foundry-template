# Deployer private key for broadcasting transactions.
# Must be funded on the target network. For local --dev, combine with AUTO_FUND_FROM_NODE=1.
PRIVATE_KEY=

# --- Optional: container behavior ---------------------------------------------

# Run the sample Deploy script after the node boots. Requires PRIVATE_KEY.
# AUTO_DEPLOY=1

# Auto-fund the deployer from Alith, the CC3 --dev pre-funded account.
# Only works against the local --dev node, never against devnet/testnet.
# AUTO_FUND_FROM_NODE=1
# AUTO_FUND_AMOUNT=10ether
